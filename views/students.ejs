<!DOCTYPE html>
<html>
<head>
    <title>Students</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>All Students</h1>

<table>
    <tr>
        <th>Name</th>
        <th>Roll No</th>
        <th>Course</th>
        <th>Project Name</th>
        <th>Completion Time</th>
        <th>Actions</th>
      
    </tr>

    <% students.forEach(student => { %>
    <tr>
        <td><%= student.name %></td>
        <td><%= student.rollNo %></td>
        <td><%= student.course %></td>
        <td><%= student.projectName %></td>
        <td><%= student.completionTime %></td>
        <td>
            <a href="/editStudent/<%= student._id %>"> Edit</a>
            <td>
    
    <a href="/deleteStudent/<%= student._id %>" 
       onclick="return confirm('Are you sure you want to delete this student?')"
       style="background:red;">
        Delete
    </a>
</td>
        </td>
    </tr>
    <% }) %>

</table>

<br>
<a href="/">Back</a>

</body>
</html>